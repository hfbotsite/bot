# Copy to .env and fill values
# cp services/.env.example services/.env

# Postgres (matches services/docker-compose.yml defaults)
POSTGRES_DB=bot_platform
POSTGRES_USER=bot
POSTGRES_PASSWORD=bot
POSTGRES_PORT=5433

# Public/internal API database URL (inside docker network)
DATABASE_URL=postgresql+psycopg://bot:bot@postgres:5432/bot_platform

# Bot runtime identity
BOT_ID=local-bot-1
RUN_ID=local-run-1
BOT_CONFIG_PATH=/app/services/bot_runtime/example.bot.json

# Exchange secrets (Bybit mainnet)
EXCHANGE_API_KEY=gUJ6CFbzoA7E7SWh9c
EXCHANGE_API_SECRET=e16fWNE0J3WKDT5cri91JtFvu89X1B5tkLay
EXCHANGE_API_PASSWORD=

# Market data
MARKET_DATA_SOURCE=ws
CANDLES_WS_URL=ws://localhost:9999/ws
CANDLES_WS_STALE_AFTER_SECONDS=30

# Mock (if MARKET_DATA_SOURCE=mock)
MOCK_SPEEDUP=60
MOCK_SEED=
MOCK_START_PRICE=100.0

# Execution conventions
POSITION_MODE=hedge

# Trading mode flags
SANDBOX=false
